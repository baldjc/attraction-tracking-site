modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_object_storage:2.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 23636
externalPort = 3000

[userenv]

[userenv.shared]
GHL_LOCATION_ID = "vEIiKAjpBkCDrabeDre7"
FROM_EMAIL = "Attraction by Video <noreply@attractionbyvideo.com>"
AUTH_TRUST_HOST = "true"
AUTH_URL = "https://attraction-tracking-site.replit.app"
NEXT_PUBLIC_GHL_LOCATION_ID = "vEIiKAjpBkCDrabeDre7"
GOOGLE_DRIVE_ROOT_FOLDER_ID = "1cHV_V8D2XjZL10AvXH1ipCW1eS2OM7un"

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
