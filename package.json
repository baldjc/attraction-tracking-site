{
  "name": "attraction-tracking-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "fuser -k 5000/tcp 2>/dev/null || true; sleep 0.5; next dev -p 5000 -H 0.0.0.0",
    "dev:reset": "fuser -k 5000/tcp 2>/dev/null || true; sleep 1; rm -rf .next; next dev -p 5000 -H 0.0.0.0",
    "build": "rm -rf .next/dev .next/cache && prisma generate && NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start -p 5000 -H 0.0.0.0",
    "worker": "npx tsx scripts/worker.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "backfill:artifacts": "npx tsx scripts/backfill-plan-artifacts.ts",
    "backfill:drive": "npx tsx scripts/backfill-drive-uploads.ts",
    "backfill:thumbnails": "npx tsx scripts/backfill-thumbnails-to-drive.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-cloud/storage": "^7.19.0",
    "@heroicons/react": "^2.2.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@replit/object-storage": "^1.0.0",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@types/pg": "^8.11.11",
    "@uppy/aws-s3": "^5.1.0",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.1",
    "@uppy/react": "^5.2.0",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^6.2.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "mammoth": "^1.12.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pg-boss": "^10.4.2",
    "prisma": "^7.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.3",
    "stripe": "^21.0.1",
    "tiptap-markdown": "^0.9.0",
    "tsx": "^4.22.4",
    "whatwg-url": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
