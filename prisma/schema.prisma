// ─────────────────────────────────────────────────────────────────────────────
// Wave 0 — Data-First Rebuild foundation
// All additions below are ADDITIVE (new enums, new models). No existing
// structures were modified destructively. Sibling-route doctrine: nothing
// here is wired into UI/APIs in Wave 0; those come in Waves 1+.
// ─────────────────────────────────────────────────────────────────────────────

enum ShootType {
  talking_head
  home_tour
}

enum RotationSlot {
  market_update
  neighbourhood_fact
  contrarian_take
