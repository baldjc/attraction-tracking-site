// Wave 4 — Content Engine wizard draft persistence. One row per user (latest
// in-progress wizard run). Auto-saved on every step transition + after async
// arrivals (idea-card batches, validation chat messages). Resume prompt is
// shown on wizard load when the row exists. Garbage collection is delete-on-
// read: each GET sweeps any expired draft for the caller before returning.
//
// `currentStep` mirrors the wizard URL `?step=` param. `propertyTypeFocus`
// is one of Any|Detached|Semi-Detached|Row/Townhouse|Apartment (no
// Multi-Family — Calgary data has no Multi-Family rows). `pickedKey` is the
// sessionStorage key for the picked idea card (Step 4 only).
model ContentEngineDraft {
  id                     String   @id @default(uuid())
  // Wave 4 beta — userId is NOT unique. A member can have several in-flight
  // wizard drafts at once (different tabs, different ideas in parallel).
  // Multi-draft surfaces (My Work, WizardDraftShell) order by updatedAt desc.
  userId                 String
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStep            String
  propertyTypeFocus      String?
  storyLeadId            String?
  leadSpansMultipleTypes Boolean  @default(false)
  rotationSlot           String?
  validatedIdea          String?  @db.Text
  storyLeadFactIds       Json?
  generatedIdeaCards     Json?
  validationContext      Json?
  pickedKey              String?
  expiresAt              DateTime
  updatedAt              DateTime @updatedAt
  createdAt              DateTime @default(now())

  // Compound index covers both "most recent draft for user" (singleton GET)
  // and "list user's drafts, newest first" (My Work) without a separate
  // userId-only index.
  @@index([userId, updatedAt])
  @@index([expiresAt])
  @@map("content_engine_drafts")
}

// Legacy v1 Content Engine chat draft persistence.
// The v1 chat (src/components/ai-tools/content-engine/ContentEngineChat.tsx)
// auto-saves the in-flight chat for a given theme so members can refresh
// without losing it. This used to live on the same `content_engine_drafts`
// table; Wave 4 reshaped that table for the wizard, so v1 got its own
// table here to avoid regressing the dashboard members are still using.
// Follow-up #30 will retire v1 entirely, at which point this model
// (and `/api/ai-tools/content-engine/chat/draft`) can be deleted.
model ContentEngineChatDraft {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme     String
  messages  Json     @default("[]")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userId, theme])
  @@map("content_engine_chat_drafts")
}

