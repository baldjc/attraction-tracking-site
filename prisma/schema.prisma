model ContentPlan {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title              String
  status             String    @default("Idea")
  theme              String?
  shootDate          DateTime?
  shootLocation      String?
  publishDate        DateTime?
  editDueDate        DateTime?
  priority           String?
  notes              String?   @db.Text
  script             String?   @db.Text
  youtubeDescription String?   @db.Text
  researchNotes      String?   @db.Text
  // Free-form scratchpad for the member's own notes & thoughts about this
  // video — separate from `notes` (talking points / outline) and
  // `researchNotes` (sourced facts) so the structured fields stay clean.
  thoughts           String?   @db.Text
  // Manual progress-track overrides — array of step keys ("idea","script",
  // "review","title","description","repurpose","ready") the user has ticked
  // by hand. Combined with auto-detection (OR) when rendering ProgressTrack.
  manualSteps        Json?
  thumbnailWords     String?
  footageLink        String?
  driveFolderLink    String?

  // Drive-file pick used as the video's thumbnail in planner views. Stored as
  // the raw Drive file id (+ friendly name for display fallback) so we can
  // proxy the binary through our own /thumbnail route — never embed Drive
  // thumbnailLink URLs directly (they expire and require auth).
  thumbnailFileId   String?
  thumbnailFileName String?

  // A/B thumbnail variants — array of { id, url, fileName, uploadedAt, score?, scoredAt? }
  // up to 3 entries. `thumbnailWinnerId` points at the chosen variant's id.
  thumbnailVariants Json?
  thumbnailWinnerId String?

  // Pinned first comment drafted for this video — posts ~60s after publish.
  pinnedComment String? @db.Text

  linkedIdeaId   String?
  linkedScriptId String?
  youtubeVideoId String?

  linkedCampaignId String?
  campaign         Campaign? @relation("PlanCampaign", fields: [linkedCampaignId], references: [id], onDelete: SetNull)
  assignedUserId   String?
  assignedUser     User?     @relation("PlanAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)

  bingeVideoId   String?
  bingeVideo     ContentPlan?  @relation("BingeChain", fields: [bingeVideoId], references: [id], onDelete: SetNull)
  bingedFromList ContentPlan[] @relation("BingeChain")

  artifacts     PlanArtifact[]
  teamNotes     PlanTeamNote[]
  assignmentLog PlanAssignmentLog[]

  // Wave 0 (data-first rebuild) — all nullable, backward compatible
  shootType         ShootType?
  rotationSlot      RotationSlot?
  linkedFactIds     Json?
  // Research Reader — ids of the EXTERNAL research sources (ResearchSource)
  // this plan's script was grounded against (the "outside lens"). Mirrors
  // linkedFactIds (member's own data) so the plan's assigned assets stay in
  // sync with the two-section "## Sources" footnote baked into the script.
  // Null/absent on every non-research plan.
  linkedResearchSourceIds Json?
  linkedStoryLeadId String?
  homeAddress       String?
  homePriceTier     String?
  homeFeatures      Json?
  titlePromise      String?       @db.Text
  visualPeak        String?       @db.Text

  // Wave 4 (propertyType lock) — pinned property type for this video.
  // Read by Script Builder v2 when building the per-neighbourhood SoT
  // lock map: if a citedFact's caveat doesn't name a property type, this
  // value is the fallback. Null means "infer from citedFacts; otherwise
  // fall back to All". Allowed values: "Detached" | "Row/Townhouse" |
  // "Apartment" | "Semi-Detached" | "All".
  propertyTypeFocus String?

  // Story Lead → Video fact provenance. How this plan's `linkedFactIds` were
  // resolved when it was minted from a Story Lead:
  //   "from_ids"              — the lead carried real MarketFact PKs
  //   "from_textual_resolver" — matched from the lead's display dataThreads
  //   "unresolved"            — no facts resolved; auto-enrichment will retry
  // Null for plans not originating from a Story Lead. Drives the wizard's
  // unresolved-facts banner vs. the auto-link review panel.
  factsResolutionState      String?
  // Aggregate (weakest) confidence of the textual resolver's matches:
  // "exact" | "close" | "fuzzy". Only set when factsResolutionState is
  // "from_textual_resolver"; null otherwise.
  factsResolutionConfidence String?

  // Soft-delete timestamp. Null = live plan; non-null = deleted (hidden from
  // every member-facing read, retained for admin restore). Replaced the old
  // "Archived" status string, which only hid plans from a few views and left
  // them leaking into dashboards, the calendar feed, binge selectors, etc.
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, publishDate])
  @@index([userId, deletedAt])
  @@index([status])
  @@index([assignedUserId])
  @@index([bingeVideoId])
  @@map("content_plans")
}

