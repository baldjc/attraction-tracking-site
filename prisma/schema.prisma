generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  foundations_member
}

enum ServiceTier {
  foundations
  editing_2
  editing_4
  mastery_2
  mastery_4
}

enum AuditType {
  lead
  baseline
  monthly
  single_video
}

enum AIToolType {
  avatar_architect
  content_engine
  title_thumbnail_analyzer
  arc_script_builder
  script_review
}

enum JobStatus {
  queued
  downloading
  analysing
  generating
  complete
  failed
}

model User {
  id                String      @id @default(uuid())
  email             String      @unique
  fullName          String?
  passwordHash      String?
  magicLinkEnabled  Boolean     @default(false)
  emailVerified     Boolean     @default(false)
  role              UserRole    @default(foundations_member)
  ghlContactId        String?
  phone               String?
  youtubeChannelUrl   String?
  youtubeHandle       String?
  youtubeChannelName  String?
  serviceTier         ServiceTier @default(foundations)
  slackUserId       String?
  skoolProfile      String?
  coachingNotes          String?
  coachingNotesUpdatedAt DateTime?
  invitedAt              DateTime?
  lastLoginAt            DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  avatarProfile   Json?
  avatarName      String?
  avatarSummary   String?
  contentThemes   Json?
  niche           String?
  city            String?

  aiToolsMonthlyCapOverride  Decimal? @db.Decimal(10, 2)

  audits               Audit[]
  auditJobs            AuditJob[]
  campaigns            Campaign[]
  links                TrackingLink[]
  scriptReviews        ScriptReview[]
  savedScripts         SavedScript[]
  savedTitles          SavedTitle[]
  savedIdeas           SavedIdea[]
  titleAnalyses        TitleAnalysis[]
  aiToolConversations  AIToolConversation[]
  aiToolUsage          AIToolUsage[]

  @@map("users")
}

model ScriptReview {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle    String
  scriptText    String
  scores        Json
  overallScore  Float
  reportContent Json
  createdAt     DateTime @default(now())

  @@map("script_reviews")
}

model Audit {
  id             String    @id @default(uuid())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditType      AuditType
  overallScore   Float?
  scores         Json
  reportContent  Json
  videosAnalysed Json?
  notionPageId   String?
  notionPageUrl  String?
  reportMonth    String?
  createdAt      DateTime  @default(now())

  auditJob AuditJob?

  @@index([userId])
  @@index([auditType])
  @@map("audits")
}

model AuditJob {
  id           String    @id @default(uuid())
  auditType    AuditType
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       JobStatus @default(queued)
  errorMessage String?
  auditId      String?   @unique
  audit        Audit?    @relation(fields: [auditId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("audit_jobs")
}

model Campaign {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  links TrackingLink[]

  @@index([userId])
  @@map("campaigns")
}

model TrackingLink {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId      String?
  campaign        Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  name            String
  destinationUrl  String
  shortCode       String    @unique
  videoTitle      String?
  leadMagnetName  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  clicks Click[]

  @@index([shortCode])
  @@index([userId])
  @@map("tracking_links")
}

model Click {
  id           String       @id @default(uuid())
  linkId       String
  link         TrackingLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  timestamp    DateTime     @default(now())
  ipAddress    String?
  userAgent    String?
  referrer     String?
  gCampaignId  String?
  gAdGroupId   String?
  gKeyword     String?
  gDevice      String?
  gNetwork     String?
  gMatchType   String?

  conversion Conversion?

  @@index([linkId])
  @@index([timestamp])
  @@map("clicks")
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model Conversion {
  id        String   @id @default(uuid())
  clickId   String   @unique
  click     Click    @relation(fields: [clickId], references: [id], onDelete: Cascade)
  type      String   @default("EMAIL_SIGNUP")
  timestamp DateTime @default(now())

  @@map("conversions")
}

model SavedScript {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle    String
  scriptOutline Json
  arcScores     Json?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@map("saved_scripts")
}

model SavedTitle {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  framework String?
  topic     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("saved_titles")
}

model SavedIdea {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme         String
  title         String
  talkingPoints Json
  framework     String?
  whyItWorks    String?
  source        String   @default("batch")
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([userId, theme])
  @@map("saved_ideas")
}

model TitleAnalysis {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle String
  scores    Json
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("title_analyses")
}

model LoginOtp {
  id        String    @id @default(uuid())
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@map("login_otps")
}

model AIToolUsage {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolType       String
  inputTokens    Int
  outputTokens   Int
  costUsd        Decimal  @db.Decimal(10, 6)
  conversationId String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("ai_tool_usage")
}

model AIToolConversation {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolType      AIToolType
  title         String
  messages      Json
  metadata      Json?
  downloadCount Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([toolType])
  @@index([createdAt])
  @@map("ai_tool_conversations")
}
