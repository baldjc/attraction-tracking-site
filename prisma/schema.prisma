generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  editor
  foundations_member
  audit_lead
}

enum AuditRequestStatus {
  pending
  audited
}

enum ServiceTier {
  foundations
  editing_2
  editing_4
  mastery_2
  mastery_4
}

enum AuditType {
  lead
  baseline
  monthly
  single_video
}

enum AIToolType {
  avatar_architect
  content_engine
  title_thumbnail_analyzer
  arc_script_builder
  script_review
  description_generator
}

enum JobStatus {
  queued
  downloading
  analysing
  generating
  complete
  failed
  cancelled
}

enum SourceType {
  YOUTUBE
  GOOGLE_ADS
  EMAIL
  EMAIL_NEWSLETTER
  META_ADS
  DIRECT_MAIL
  BLOG_POSTS
  OTHER
}

model User {
  id                String      @id @default(uuid())
  email             String      @unique
  fullName          String?
  passwordHash      String?
  magicLinkEnabled  Boolean     @default(false)
  emailVerified     Boolean     @default(false)
  role              UserRole    @default(foundations_member)
  ghlContactId        String?
  phone               String?
  youtubeChannelUrl   String?
  youtubeHandle       String?
  youtubeChannelName      String?
  youtubeChannelThumbnail String?
  serviceTier         ServiceTier @default(foundations)
  stripeCustomerId        String?   @unique
  stripeSubscriptionId    String?
  subscriptionStatus      String?
  stripePlanName          String?
  stripeCurrentPeriodEnd  DateTime?
  stripePriceAmount       Int?
  stripeCurrency          String?
  lastPaymentReminderSentAt DateTime?
  slackUserId       String?
  skoolProfile      String?
  coachingNotes          String?
  coachingNotesUpdatedAt DateTime?
  invitedAt              DateTime?
  lastLoginAt            DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  allowedMemberIds  Json?

  avatarProfile   Json?
  videoThemes     String?
  avatarName      String?
  avatarSummary   String?
  contentThemes   Json?
  niche           Json?
  city            String?
  thankYouPageUrl     String?
  creatorCredentials  String?

  aiToolsMonthlyCapOverride  Decimal? @db.Decimal(10, 2)

  repurposeName     String?
  repurposeBusiness String?
  repurposeListSize String?
  repurposeVoice    String?
  savedLinks        Json?
  descriptionBoilerplate String? @db.Text

  // Onboarding
  onboardingComplete     Boolean   @default(false)
  onboardingDismissedAt  DateTime?
  incomeGoal             String?
  postingRhythm          Int?
  biggestChallenge       String?

  lastYoutubeSyncAt    DateTime? @map("last_youtube_sync_at")

  assetsDriveLink  String?
  clientHubEnabled Boolean  @default(true)
  calendarToken    String?  @unique

  audits               Audit[]
  auditJobs            AuditJob[]
  campaigns            Campaign[]
  scriptReviews        ScriptReview[]
  savedScripts         SavedScript[]
  savedTitles          SavedTitle[]
  savedIdeas           SavedIdea[]
  titleAnalyses        TitleAnalysis[]
  aiToolConversations  AIToolConversation[]
  aiToolUsage          AIToolUsage[]
  repurposedContent    RepurposedContent[]
  kbEntries            KnowledgeBaseEntry[]
  savedItems           SavedItem[]
  youtubeVideos        YouTubeVideo[]
  channelSnapshots     YouTubeChannelSnapshot[]
  workbookResponses    MemberWorkbookResponse[]
  lessonProgress       MemberLessonProgress[]
  homework             MemberHomework[]
  waitlistEntries      ServiceWaitlistEntry[]
  helpConversations    HelpConversation[]
  contentPlans         ContentPlan[]
  clientCalls          ClientCall[]     @relation("ClientCalls")
  createdCalls         ClientCall[]     @relation("CallCreator")
  quickLinks           ClientQuickLink[]
  scriptDrafts         ScriptDraft[]
  contentEngineDrafts  ContentEngineDraft[]
  changelogViews       ChangelogEntryView[]

  @@map("users")
}

model ResourceLesson {
  id            String   @id @default(uuid())
  title         String
  lessonNumber  String
  sessionNumber Int
  skoolUrl      String   @default("")
  fullTranscript String  @db.Text
  principles    String[]
  createdAt     DateTime @default(now())

  @@map("course_lessons")
}

model QACall {
  id             String   @id @default(uuid())
  fathomId       String   @unique
  title          String
  callDate       DateTime
  fathomShareUrl String
  fullTranscript String   @db.Text
  duration       Int?
  status         String   @default("pending_review")
  errorMessage   String?
  createdAt      DateTime @default(now())

  @@map("qa_calls")
}

model KnowledgeBaseEntry {
  id                String   @id @default(uuid())
  sourceType        String
  sourceId          String
  principles        String[]
  subTopic          String   @default("")
  summary           String
  searchableText    String   @db.Text
  timestampStart    Int?
  timestampEnd      Int?
  memberId          String?
  member            User?    @relation(fields: [memberId], references: [id], onDelete: SetNull)
  isGeneralTeaching Boolean  @default(true)
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  savedItems SavedItem[]

  @@index([status])
  @@index([sourceType, sourceId])
  @@index([memberId])
  @@index([principles])
  @@map("knowledge_base_entries")
}

model SavedItem {
  id                   String             @id @default(uuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeBaseEntryId String
  knowledgeBaseEntry   KnowledgeBaseEntry @relation(fields: [knowledgeBaseEntryId], references: [id], onDelete: Cascade)
  savedAt              DateTime           @default(now())

  @@unique([userId, knowledgeBaseEntryId])
  @@map("saved_items")
}

model ScriptReview {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle    String
  scriptText    String
  scores        Json
  overallScore  Float
  reportContent Json
  createdAt     DateTime @default(now())

  @@map("script_reviews")
}

model Audit {
  id             String    @id @default(uuid())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditType      AuditType
  overallScore   Float?
  scores         Json
  reportContent  Json
  videosAnalysed Json?
  notionPageId   String?
  notionPageUrl  String?
  reportMonth    String?
  createdAt      DateTime  @default(now())

  youtubeVideoId String?       @map("youtube_video_id")
  youtubeVideo   YouTubeVideo? @relation(fields: [youtubeVideoId], references: [id])

  auditJob AuditJob?

  @@index([userId])
  @@index([auditType])
  @@map("audits")
}

model AuditJob {
  id           String    @id @default(uuid())
  auditType    AuditType
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       JobStatus @default(queued)
  errorMessage String?
  auditId      String?   @unique
  audit        Audit?    @relation(fields: [auditId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("audit_jobs")
}

model Campaign {
  id             String     @id @default(uuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  destinationUrl String
  leadMagnetUrl  String?
  sourceType     SourceType @default(YOUTUBE)
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  links TrackingLink[]

  @@index([userId])
  @@map("campaigns")
}

model TrackingLink {
  id                    String    @id @default(uuid())
  campaignId            String
  campaign              Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name                  String
  source                String    @default("youtube")
  destinationOverride   String    @default("landing_page")
  channel               String?
  refCode               String    @unique
  youtubeVideoUrl       String?
  youtubeVideoId        String?
  youtubeThumbnailUrl   String?
  youtubeViewCount      Int       @default(0)
  youtubeViewsUpdatedAt DateTime?
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())

  clicks Click[]

  @@index([refCode])
  @@index([campaignId])
  @@map("tracking_links")
}

model Click {
  id             String       @id @default(uuid())
  trackingLinkId String
  link           TrackingLink @relation(fields: [trackingLinkId], references: [id], onDelete: Cascade)
  refCode        String
  sessionId      String
  ipAddress      String?
  city           String?
  province       String?
  country        String?
  countryCode    String?
  userAgent      String?
  referrer       String?
  visitorType    String?      @map("visitor_type")
  timestamp      DateTime     @default(now())

  pageViews PageView[]
  lead      Lead?

  @@index([trackingLinkId])
  @@index([refCode])
  @@index([sessionId])
  @@index([timestamp])
  @@map("clicks")
}

model PageView {
  id        String   @id @default(uuid())
  clickId   String
  click     Click    @relation(fields: [clickId], references: [id], onDelete: Cascade)
  pageUrl   String
  timestamp DateTime @default(now())

  @@index([clickId])
  @@map("page_views")
}

model Lead {
  id        String   @id @default(uuid())
  clickId   String   @unique
  click     Click    @relation(fields: [clickId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())

  @@index([clickId])
  @@map("leads")
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model SavedScript {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle    String
  scriptOutline Json
  arcScores     Json?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@map("saved_scripts")
}

model SavedTitle {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  framework String?
  topic     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("saved_titles")
}

model SavedIdea {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme         String
  title         String
  talkingPoints Json
  dataToFind    String?
  framework     String?
  whyItWorks    String?
  source        String   @default("batch")
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([userId, theme])
  @@map("saved_ideas")
}

model TitleAnalysis {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle String
  scores     Json
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("title_analyses")
}

model LoginOtp {
  id        String    @id @default(uuid())
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@map("login_otps")
}

model AIToolUsage {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolType       String
  inputTokens    Int
  outputTokens   Int
  costUsd        Decimal  @db.Decimal(10, 6)
  conversationId String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("ai_tool_usage")
}

model AIToolConversation {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolType      AIToolType
  title         String
  messages      Json
  metadata      Json?
  downloadCount Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([toolType])
  @@index([createdAt])
  @@map("ai_tool_conversations")
}

model RepurposedContent {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle   String
  toolType     String
  output       Json
  editedOutput String?
  createdAt    DateTime @default(now())

  @@index([userId, toolType, createdAt])
  @@map("repurposed_content")
}

model YouTubeVideo {
  id           String   @id @default(uuid())
  userId       String
  videoId      String
  title        String
  publishedAt  DateTime
  thumbnailUrl String?
  viewCount    Int      @default(0)
  likeCount    Int      @default(0)
  commentCount Int      @default(0)
  duration     String?
  discoveredAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  audits Audit[]

  @@unique([userId, videoId])
  @@map("youtube_videos")
}

model YouTubeChannelSnapshot {
  id              String   @id @default(uuid())
  userId          String
  subscriberCount Int
  totalVideoCount Int
  totalViewCount  BigInt
  snapshotAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("youtube_channel_snapshots")
}

// ── Academy / Foundations Library ────────────────────────────────────────────

model CourseSection {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?  @db.Text
  sortOrder   Int
  published   Boolean  @default(true)
  moduleType  String   @default("foundations")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons CourseLesson[]

  @@map("course_sections")
}

model CourseLesson {
  id            String   @id @default(uuid())
  sectionId     String
  title         String
  slug          String   @unique
  youtubeUrl    String?
  description   String?  @db.Text
  keyTakeaways  String?  @db.Text
  actionItems   String?  @db.Text
  sortOrder     Int
  published     Boolean  @default(true)
  principleTags Json     @default("[]")
  aiToolLink    String?
  aiToolLabel   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  section        CourseSection          @relation(fields: [sectionId], references: [id])
  workbookFields LessonWorkbookField[]
  progress       MemberLessonProgress[]
  homework       MemberHomework[]

  @@map("academy_lessons")
}

model LessonWorkbookField {
  id              String   @id @default(uuid())
  lessonId        String
  fieldType       String
  label           String
  placeholderText String?
  sortOrder       Int
  config          Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lesson    CourseLesson             @relation(fields: [lessonId], references: [id])
  responses MemberWorkbookResponse[]

  @@map("lesson_workbook_fields")
}

model MemberWorkbookResponse {
  id              String   @id @default(uuid())
  userId          String
  workbookFieldId String
  response        Json
  updatedAt       DateTime @updatedAt

  user          User                @relation(fields: [userId], references: [id])
  workbookField LessonWorkbookField @relation(fields: [workbookFieldId], references: [id])

  @@unique([userId, workbookFieldId])
  @@map("member_workbook_responses")
}

model MemberLessonProgress {
  id          String    @id @default(uuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?

  user   User         @relation(fields: [userId], references: [id])
  lesson CourseLesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@map("member_lesson_progress")
}

model MemberHomework {
  id            String   @id @default(uuid())
  userId        String
  lessonId      String
  homeworkItems Json
  updatedAt     DateTime @updatedAt

  user   User         @relation(fields: [userId], references: [id])
  lesson CourseLesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@map("member_homework")
}

model ServiceCategory {
  id                String   @id @default(uuid())
  name              String
  slug              String   @unique
  description       String?
  icon              String   @default("PuzzlePieceIcon")
  accentColour      String   @default("blue")
  sortOrder         Int      @default(0)
  published         Boolean  @default(true)
  emoji             String?
  tagline           String?
  highlighted       Boolean  @default(false)
  includesRef       String?
  cardExtras        Json?
  addonLabel        String?
  addonPriceNote    String?
  footerNote        String?
  jaredIncludedNote String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  packages          ServicePackage[]

  @@map("service_categories")
}

model ServicePackage {
  id                String   @id @default(uuid())
  categoryId        String
  name              String
  price             String
  priceNote         String?
  badge             String?
  subtitle          String?
  features          Json     @default("[]")
  highlightFeatures Json?
  stripeUrl         String?
  waitlist          Boolean  @default(false)
  sortOrder         Int      @default(0)
  published         Boolean  @default(true)
  videoCount        Int?
  isAddonVariant    Boolean  @default(false)
  priceAmount       Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  category          ServiceCategory @relation(fields: [categoryId], references: [id])
  waitlistEntries   ServiceWaitlistEntry[]

  @@map("service_packages")
}

model ServiceWaitlistEntry {
  id        String   @id @default(uuid())
  packageId String
  userId    String
  message   String?
  createdAt DateTime @default(now())
  package   ServicePackage @relation(fields: [packageId], references: [id])
  user      User           @relation(fields: [userId], references: [id])

  @@unique([packageId, userId])
  @@map("service_waitlist_entries")
}

model HelpConversation {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  HelpMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
  @@map("help_conversations")
}

model HelpMessage {
  id             String           @id @default(uuid())
  conversationId String
  conversation   HelpConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String           @db.Text
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@map("help_messages")
}

model SiteConfig {
  id                Int      @id @default(autoincrement())
  key               String   @unique
  value             String
  label             String?
  fieldType         String   @default("text") @map("field_type")
  category          String   @default("webinar")
  ghlCustomValueKey String?  @map("ghl_custom_value_key")
  sortOrder         Int      @default(0) @map("sort_order")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy         String?  @map("updated_by")

  @@map("site_config")
}

model AuditRequest {
  id                   String             @id @default(uuid())
  fullName             String
  email                String
  phone                String?
  youtubeChannelUrl    String
  currentYoutubeIncome String?
  desiredYoutubeIncome String?
  status               AuditRequestStatus @default(pending)
  userId               String?
  auditId              String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([email])
  @@index([status])
  @@map("audit_requests")
}

model ContentPlan {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  status          String    @default("Idea")
  theme           String?
  shootDate       DateTime?
  publishDate     DateTime?
  editDueDate     DateTime?
  priority        String?
  notes           String?   @db.Text
  script          String?   @db.Text
  youtubeDescription String? @db.Text
  researchNotes   String?   @db.Text
  thumbnailWords  String?
  footageLink     String?
  driveFolderLink String?

  linkedIdeaId    String?
  linkedScriptId  String?
  youtubeVideoId  String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, publishDate])
  @@map("content_plans")
}

model ClientCall {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("ClientCalls", fields: [userId], references: [id], onDelete: Cascade)

  fathomUrl   String
  callDate    DateTime
  topic       String?
  notes       String?  @db.Text

  createdById String
  createdBy   User     @relation("CallCreator", fields: [createdById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, callDate])
  @@map("client_calls")
}

model ClientQuickLink {
  id        String @id @default(uuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  label     String
  url       String
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("client_quick_links")
}

model ScriptDraft {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle        String
  initialData       Json
  messages          Json
  currentSection    String   @default("research_strategy")
  completedSections Json     @default("[]")
  sectionApprovals  Json     @default("[]")
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@unique([userId, videoTitle])
  @@index([userId])
  @@map("script_drafts")
}

model ContentEngineDraft {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme     String
  messages  Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([userId, theme])
  @@index([userId])
  @@map("content_engine_drafts")
}

// ═══════════════════════════════════════════════════
// SEO INTELLIGENCE MODULE
// ═══════════════════════════════════════════════════

enum Audience {
  FIRST_TIME_BUYER
  MOVE_UP_BUYER
  MOVE_DOWN_RIGHT_SIZER
  SELLER
  INVESTOR
  RELOCATOR
  LUXURY
  NEW_CONSTRUCTION
  RENTER_CONSIDERING_BUYING
}

enum StressTheme {
  MARKET_UPDATES
  PRE_BUYING_DECISION
  NEIGHBOURHOODS
  EQUITY
  EDUCATION
  NUMBERS
  RELOCATION
}

enum ContentAngle {
  MARKET_UPDATE
  INTEREST_RATE_ECONOMIC
  PROCESS_WALKTHROUGH
  MISTAKES_WARNINGS
  MYTH_BUSTING
  FINANCIAL_STRATEGY
  PRICING_VALUATION
  NEGOTIATION_TACTICS
  STAGING_PRESENTATION
  NEIGHBOURHOOD_ROUNDUP
  HIDDEN_GEMS_STREET_LEVEL
  RELOCATION_CITY_GUIDE
  COMPARISON
  CASE_STUDY
  QA_FAQ
  DAY_IN_THE_LIFE
  TOOLS_RESOURCES
}

enum ContentStyle {
  DATA_HEAVY
  VALUE_HEAVY
  BALANCED
}

enum IntelRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Client {
  id                String     @id @default(uuid())
  name              String
  email             String?
  city              String
  province          String?
  country           String     @default("Canada")
  niche             String
  audiencePrimary   Audience
  audienceSecondary Audience[]
  ownChannelUrl     String?
  ownChannelId      String?
  avatarDocId       String?
  cityVocabulary    Json?
  nicheVocabulary   Json?
  notes             String?    @db.Text
  seoMonthlySpend   Float      @default(0)
  seoMonthlyCap     Float      @default(50)
  active            Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  seoSearches        SeoSearch[]
  seoClusters        SeoCluster[]
  competitors        ClientCompetitor[]
  contentIdeas       ContentIdea[]
  intelRuns          IntelRun[]
  vocabularyTests    VocabularyTest[]
  vocabularyProfiles VocabularyProfile[]

  @@map("intel_clients")
}

model IntelChannel {
  id              String    @id @default(uuid())
  ytChannelId     String    @unique
  handle          String?
  title           String
  description     String?   @db.Text
  city            String?
  niche           String?
  audiencePrimary Audience?
  subscribers     Int?
  totalViews      BigInt?
  videoCount      Int?
  publishedAt     DateTime?
  thumbnailUrl    String?
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  videos           IntelVideo[]
  competitorLinks  ClientCompetitor[]
  channelSnapshots IntelChannelSnapshot[]

  @@map("intel_channels")
}

model IntelChannelSnapshot {
  id          String       @id @default(uuid())
  channelId   String
  channel     IntelChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  capturedAt  DateTime     @default(now())
  subscribers Int
  totalViews  BigInt
  videoCount  Int

  @@index([channelId, capturedAt])
  @@map("intel_channel_snapshots")
}

model IntelVideo {
  id                  String       @id @default(uuid())
  ytVideoId           String       @unique
  channelId           String
  channel             IntelChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  title               String
  description         String?      @db.Text
  publishedAt         DateTime
  durationSec         Int?
  views               BigInt
  likes               Int?
  comments            Int?
  thumbnailUrl        String?
  tags                String[]
  transcript          String?      @db.Text
  transcriptFetchedAt DateTime?
  outlierMultiple     Float?
  isOutlier           Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  analysis IntelVideoAnalysis?

  @@index([channelId, publishedAt])
  @@index([isOutlier])
  @@map("intel_videos")
}

model IntelVideoAnalysis {
  id                    String         @id @default(uuid())
  videoId               String         @unique
  video                 IntelVideo     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  audiencePrimary       Audience?
  audienceSecondary     Audience[]
  contentAnglePrimary   ContentAngle?
  contentAngleSecondary ContentAngle[]
  contentStyle          ContentStyle?
  stressThemes          StressTheme[]
  hookType              String?
  titleFramework        String?
  arcAttention          Float?
  arcRevelation         Float?
  arcConnection         Float?
  arcOverall            Float?
  whyItWorked           String?        @db.Text
  patternsDetected      Json?
  analysedAt            DateTime       @default(now())

  @@map("intel_video_analyses")
}

model HookPattern {
  id            String         @id @default(uuid())
  name          String         @unique
  description   String         @db.Text
  examples      Json
  audienceFit   Audience[]
  themeFit      StressTheme[]
  angleFit      ContentAngle[]
  outlierCount  Int            @default(0)
  avgMultiple   Float?
  trendingDelta Float?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("intel_hook_patterns")
}

model TitlePattern {
  id            String         @id @default(uuid())
  name          String         @unique
  template      String
  description   String         @db.Text
  examples      Json
  audienceFit   Audience[]
  themeFit      StressTheme[]
  angleFit      ContentAngle[]
  outlierCount  Int            @default(0)
  avgMultiple   Float?
  trendingDelta Float?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("intel_title_patterns")
}

model ThumbnailPattern {
  id           String         @id @default(uuid())
  name         String         @unique
  description  String         @db.Text
  examples     Json
  audienceFit  Audience[]
  themeFit     StressTheme[]
  angleFit     ContentAngle[]
  outlierCount Int            @default(0)
  avgMultiple  Float?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("intel_thumbnail_patterns")
}

model TopicTrend {
  id                  String        @id @default(uuid())
  topic               String
  audience            Audience?
  theme               StressTheme?
  angle               ContentAngle?
  city                String?
  monthlyOutlierCounts Json
  trendDirection      String?
  trendingScore       Float?
  updatedAt           DateTime      @updatedAt

  @@map("intel_topic_trends")
}

model SwipeFileEntry {
  id           String        @id @default(uuid())
  videoId      String?
  title        String
  thumbnailUrl String?
  notes        String?       @db.Text
  tags         String[]
  audience     Audience?
  theme        StressTheme?
  angle        ContentAngle?
  createdBy    String
  createdAt    DateTime      @default(now())

  @@map("intel_swipe_file")
}

model SeoSearch {
  id          String    @id @default(uuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  source      String
  seedKeyword String
  rawResponse Json
  createdAt   DateTime  @default(now())

  keywords SeoKeyword[]

  @@index([clientId, createdAt])
  @@map("intel_seo_searches")
}

model SeoKeyword {
  id            String      @id @default(uuid())
  searchId      String
  search        SeoSearch   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  clusterId     String?
  cluster       SeoCluster? @relation(fields: [clusterId], references: [id])
  keyword       String
  volume        Int?
  cpc           Float?
  difficulty    Float?
  ytVolume      Int?
  ytCompetition Float?
  intent        String?
  isQuestion    Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@index([searchId])
  @@index([clusterId])
  @@map("intel_seo_keywords")
}

model SeoCluster {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  theme     String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  keywords SeoKeyword[]

  @@index([clientId])
  @@map("intel_seo_clusters")
}

model ClientCompetitor {
  id        String       @id @default(uuid())
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  channelId String
  channel   IntelChannel @relation(fields: [channelId], references: [id])
  notes     String?
  addedAt   DateTime     @default(now())

  @@unique([clientId, channelId])
  @@map("intel_client_competitors")
}

model ContentIdea {
  id                 String        @id @default(uuid())
  clientId           String
  client             Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title              String
  outline            String?       @db.Text
  sourceCluster      String?
  audience           Audience?
  theme              StressTheme?
  angle              ContentAngle?
  style              ContentStyle?
  hookPatternId      String?
  titlePatternId     String?
  status             String        @default("idea")
  generatedFromRunId String?
  createdAt          DateTime      @default(now())

  @@index([clientId, status])
  @@map("intel_content_ideas")
}

model VocabularyTest {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  city      String
  variants  Json
  winner    String
  runnerUps String[]
  avoid     String[]
  testedAt  DateTime @default(now())
  expiresAt DateTime

  @@index([clientId, city])
  @@map("intel_vocabulary_tests")
}

model IntelRun {
  id                String         @id @default(uuid())
  clientId          String?
  client            Client?        @relation(fields: [clientId], references: [id])
  inputChannelUrl   String
  resolvedChannelId String?
  status            IntelRunStatus @default(PENDING)
  startedAt         DateTime       @default(now())
  completedAt       DateTime?
  failedReason      String?
  reportJson        Json?
  reportMarkdown    String?        @db.Text
  costEstimate      Float?
  createdBy         String

  @@index([clientId])
  @@index([status])
  @@map("intel_runs")
}

model VocabularyProfile {
  id           String   @id @default(uuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  term         String
  definition   String?  @db.Text
  category     String?
  exampleUsage String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([clientId])
  @@map("intel_vocabulary_profiles")
}

model ApiCache {
  key       String   @id
  provider  String
  response  Json
  cachedAt  DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
  @@map("intel_api_cache")
}

model ChangelogEntry {
  id        String   @id @default(cuid())
  title     String
  body      String
  emoji     String   @default("✨")
  type      String   @default("changelog")
  createdAt DateTime @default(now())
  published Boolean  @default(true)

  views     ChangelogEntryView[]

  @@map("changelog_entries")
}

model ChangelogEntryView {
  id      String   @id @default(cuid())
  entryId String
  entry   ChangelogEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  seenAt  DateTime @default(now())

  @@unique([entryId, userId])
  @@index([userId])
  @@map("changelog_entry_views")
}
