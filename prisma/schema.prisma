  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketName         String
  mlsSource          String?
  columnMapping      Json?
  priceTiers         Json?
  moiThresholds      Json?
  neighbourhoodVocab Json?
  highEndException   Json?
  keywordKit         Json?
  primaryAvatar      Json?
  subPersonas        Json?
  // Ship B — Done-With-You member voice guide. Layer-2 override on top of the
  // default voice register baked into script-builder-mode-prompt.ts. Gated by
  // the `tool_member_voice_guide` feature flag — Foundations tier members do
  // not see the upload UI and these fields stay null for them.
  voiceGuide            String?   @db.Text
  voiceGuideUploadedAt  DateTime?
  voiceGuideSourceFile  String?
  // Onboarding Wizard Step 5 — Team credibility numbers. Used by Script Builder
  // for credibility-moment lines so it never has to invent stats like
  // "after helping 4,000 families". Auto-fill formula on the wizard:
  // 8760 / teamAnnualTransactionCount = "a family every N hours".
  teamYearsInBusiness        Int?
  teamFamiliesHelped         Int?
  teamAnnualTransactionCount Int?
  teamSize                   Int?
  teamCredibilityNotes       String?   @db.Text
  configuredAt       DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("market_configs")
}

model MarketDataUpload {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  configSnapshot    Json?
  label             String
  monthYear         String
  csvFileName       String
  csvStorageUrl     String?
  rowCount          Int
  status            UploadStatus     @default(pending)
  uploadedAt        DateTime         @default(now())
  validatedAt       DateTime?
  validationCostUsd Float?
  validationError   String?          @db.Text
  rawValidatorOutput String?         @db.Text
  retryCount        Int              @default(0)
  backfillEmailedAt DateTime?

  facts             MarketFact[]
  storyLeads        MarketStoryLead[]
  aggregatedMetrics AggregatedMetric[]

  @@index([userId, monthYear])
  @@map("market_data_uploads")
}

// Wave 1 deterministic aggregations — ground-truth numbers computed from
// the CSV BEFORE Sonnet validation runs. Script Builder v2 injects these
// into Claude as "source of truth" so it can't fabricate or misattribute
// stats. Backfilled for historical uploads via `scripts/backfill-aggregated-metrics.ts`.
model AggregatedMetric {
  id                   String           @id @default(cuid())
  userId               String
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadId             String
  upload               MarketDataUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  neighbourhood        String
  /// "All" when the AggregatedGroup had propertyType=null (city-wide rollup).
  propertyType         String           @default("All")
  /// Always null for Wave 1 — tiered subgroups are intentionally NOT persisted
  /// because the script writer queries on (neighbourhood, propertyType) only.
  priceTier            String?
  metricFamily         MetricFamily
  /// AggregatedGroup field name this row was sourced from, e.g. "medianPrice",
  /// "moiStrict", "domMedian", "spLpRatio", "psf", "failureRate", "activeCount".
  /// Disambiguates rows within the same family if we add variants later.
  metricKey            String
  metricValue          Float
  sampleSize           Int
  monthYear            String

  yoyDelta             Float?
  rolling90dValue      Float?
  compositionShiftFlag Boolean          @default(false)

  createdAt            DateTime         @default(now())

  @@unique([userId, uploadId, neighbourhood, propertyType, metricFamily, metricKey])
  @@index([userId, neighbourhood, propertyType])
  @@index([uploadId])
  @@map("aggregated_metrics")
}

model MarketFact {
  id                   String           @id @default(cuid())
  userId               String
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadId             String
  upload               MarketDataUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  neighbourhood        String
  propertyType         String?
  priceTier            String?

  metricName           String
  metricFamily         MetricFamily
  metricValue          Float?
  metricValueString    String?

  sampleSize           Int?
  timeWindow           String?
  dateContext          DateTime?

  sourceUrl            String?
  sourceTitle          String?
  notes                String?          @db.Text

  marketType           MarketType?
  trajectory           Trajectory?
  usageClass           FactUsageClass

  compositionShiftFlag Boolean          @default(false)
  triangulationStatus  String?
  yoyValue             Float?
  rolling90dValue      Float?
  crebAligned          Boolean?
  viewerCaveat         String?          @db.Text

  // Wave 1 Phase 2A — CREB-alignment + usage notes (all nullable, additive only)
  moiStrict            Float?
  moiInclusive         Float?
  domMedian            Float?
  domAverage           Float?
  crebDeltaEstimate    String?          @db.Text
  inventoryGapWithCreb Float?
  failureRateFormula   String?          @db.Text
  usageNotes           String?          @db.Text

  createdAt            DateTime         @default(now())

  @@index([userId, neighbourhood])
  @@index([uploadId])
  @@index([metricFamily, usageClass])
  @@map("market_facts")
}

model MarketStoryLead {
  id                    String           @id @default(cuid())
  userId                String
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadId              String
  upload                MarketDataUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  scanType              Int
  pattern               String           @db.Text
  dataThreads           Json
  whyItMatters          String           @db.Text

  suggestedRotationSlot RotationSlot?
  suggestedSubPersonas  Json?
  suggestedFramework    String?
  tactileType           String?

  // Wave 1 Phase 2A — additive only
  label                 String?
  isThesisLead          Boolean          @default(false)
  displayOrder          Int              @default(0)

  claimedByIdeaId       String?
  createdAt             DateTime         @default(now())

  @@index([userId])
  @@index([uploadId])
  @@map("market_story_leads")
}

// Wave 1.5 (data-first rebuild) — Neighbourhood Knowledge Base.
// Per-member structured neighbourhood research, generated externally via the
// member's preferred AI research tool, then parsed back into per-neighbourhood
// profiles. Consumed by Wave 3 Script Builder for hyper-local content.
model NeighbourhoodProfile {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  neighbourhood   String
  content         String   @db.Text
  summary         String?  @db.Text
  sourceFile      String?
  uploadBatchId   String?
  lastUpdatedAt   DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([userId, neighbourhood])
  @@index([userId])
  @@index([uploadBatchId])
  @@map("neighbourhood_profiles")
}

model NeighbourhoodResearchUpload {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawContent        String   @db.Text
  sourceFileName    String?
  toolUsed          String?
  parsedAt          DateTime?
  profileCount      Int      @default(0)
  parseCostUsd      Float?
  uploadedAt        DateTime @default(now())
  unmatchedSections Json?

  @@index([userId])
  @@map("neighbourhood_research_uploads")
}
