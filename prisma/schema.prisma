  should_you
}

enum MarketType {
  sellers
  balanced
  buyers
  balanced_high_end
}

enum Trajectory {
  tightening
  stable
  loosening
  loosening_fast
}

enum FactUsageClass {
  headline_safe
  supporting_texture_only
  rejected
}

enum MetricFamily {
  MOI
  BENCHMARK
  PSF
  MEDIAN
  DOM
  SP_LP
  // Wave 1 Phase 2A — appended only (do NOT reorder existing values).
  AVG
  INVENTORY
  FAILURE_RATE
  OTHER
  // Phase 1 fix (Known Issue #1) — absorption rate (Sold ÷ Active), its own
  // family so it gets a dedicated sample floor + formatter. Appended last.
  ABSORPTION
}

enum UploadStatus {
  pending
  validating
  validated
  failed
}

model MarketConfig {
  id                         String    @id @default(cuid())
  userId                     String    @unique
  user                       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketName                 String
  mlsSource                  String?
  columnMapping              Json?
  priceTiers                 Json?
  moiThresholds              Json?
  neighbourhoodVocab         Json?
  highEndException           Json?
  // Market-agnostic parameterization (replaces hardcoded Calgary/CREB knowledge
  // in the Fact Validator prompt). Null = fall back to per-source seed defaults
  // resolved from mlsSource (see MARKET_SOURCE_DEFAULTS in market-config.ts).
  //   statusCodes:              StatusCode[]  — board MLS status-code vocab + canonical mapping
  //   propertyTypeVocab:        { types: string[]; mergeRule?: string }
  //   sourceAuthority:          published-board display name (e.g. "CREB", "NTREIS")
  //   moiHighEndExceptionFloor: { detached: number; condo: number }
  statusCodes                Json?
  propertyTypeVocab          Json?
  sourceAuthority            String?
  moiHighEndExceptionFloor   Json?
  // OPTIONAL explicit override for status-bucketing. Source of truth is
  // `statusCodes` (+ MARKET_SOURCE_DEFAULTS resolved from mlsSource); this field
  // only exists to let an admin force the sold/offMarket/active/pending buckets
  // for a market whose raw labels don't fit the canonical statusCodes mapping.
  // Shape: { sold: string[]; offMarket: string[]; active: string[]; pending: string[] }
  // Resolution precedence (see resolveStatusMapping in market-status-buckets.ts):
  //   statusMapping (this field) -> derived from statusCodes -> MARKET_SOURCE_DEFAULTS.
  statusMapping              Json?
  keywordKit                 Json?
  primaryAvatar              Json?
  subPersonas                Json?
  // Ship B — Done-With-You member voice guide. Layer-2 override on top of the
  // default voice register baked into script-builder-mode-prompt.ts. Gated by
  // the `tool_member_voice_guide` feature flag — Foundations tier members do
  // not see the upload UI and these fields stay null for them.
  voiceGuide                 String?   @db.Text
  voiceGuideUploadedAt       DateTime?
  voiceGuideSourceFile       String?
  // Active voice selection for the Content Manager / Script Builder. "custom"
  // (or null — the legacy default) → use the uploaded voiceGuide above; "default"
  // → keep the guide on file but write in the built-in register baked into
  // script-builder-mode-prompt.ts. Toggled from the Content Manager voice chip
  // so a member can switch without deleting (and re-uploading) their guide.
  voiceMode                  String?   @default("custom")
  // Onboarding Wizard Step 5 — Team credibility numbers. Used by Script Builder
  // for credibility-moment lines so it never has to invent stats like
  // "after helping 4,000 families". Auto-fill formula on the wizard:
  // 8760 / teamAnnualTransactionCount = "a family every N hours".
  teamYearsInBusiness        Int?
  teamFamiliesHelped         Int?
  teamAnnualTransactionCount Int?
  teamSize                   Int?
  teamCredibilityNotes       String?   @db.Text
  configuredAt               DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@map("market_configs")
}

model MarketDataUpload {
  id                 String       @id @default(cuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  configSnapshot     Json?
  label              String
  monthYear          String
  csvFileName        String
  csvStorageUrl      String?
  rowCount           Int
  status             UploadStatus @default(pending)
  uploadedAt         DateTime     @default(now())
  validatedAt        DateTime?
  validationCostUsd  Float?
  factYieldPct       Float?
  validationError    String?      @db.Text
  rawValidatorOutput String?      @db.Text
  retryCount         Int          @default(0)
  // Resilience to transient AI-provider outages. When a validation pass dies on
  // a transient Anthropic error (5xx/529/api_error/connection reset), it is NOT
  // marked failed — it stays `validating` and is rescheduled: `nextAttemptAt`
  // holds when the next background auto-retry is due, and `autoRetryCount` tracks
  // how many transient retries have been scheduled (separate from `retryCount`,
  // which is the process-death/manual-recovery budget). The validation-recovery
  // watchdog fires due rows; once the ~2h backoff window is exhausted the upload
  // is marked failed with a calm, retryable message.
  autoRetryCount     Int          @default(0)
  nextAttemptAt      DateTime?
  backfillEmailedAt  DateTime?

  facts             MarketFact[]
  storyLeads        MarketStoryLead[]
  aggregatedMetrics AggregatedMetric[]

  @@index([userId, monthYear])
  @@index([status, nextAttemptAt])
  @@map("market_data_uploads")
}

// Wave 1 deterministic aggregations — ground-truth numbers computed from
// the CSV BEFORE Sonnet validation runs. Script Builder v2 injects these
// into Claude as "source of truth" so it can't fabricate or misattribute
// stats. Backfilled for historical uploads via `scripts/backfill-aggregated-metrics.ts`.
model AggregatedMetric {
  id       String           @id @default(cuid())
  userId   String
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadId String
  upload   MarketDataUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  neighbourhood   String
  /// Knowledge-Base Merge & Clean: stable link to the canonical area this row's
  /// (raw) neighbourhood was folded into. Null on rows written before a merge
  /// run applied, or when no alias exists. `neighbourhood` already stores the
  /// canonical display name after a merge re-aggregation; this is the durable id.
  canonicalAreaId String?
  /// "All" when the AggregatedGroup had propertyType=null (city-wide rollup).
  propertyType    String       @default("All")
  /// Null for the (neighbourhood, propertyType) overall rollup; a tier name
  /// (from MarketConfig.priceTiers) for a persisted price-tier subgroup. Wave 6a
  /// (Phase 1) promotes the deterministic layer to primary and now persists tier
  /// subgroups additively, so this is part of the uniqueness key below.
  priceTier       String?
  metricFamily    MetricFamily
  /// AggregatedGroup field name this row was sourced from, e.g. "medianPrice",
  /// "moiStrict", "domMedian", "spLpRatio", "psf", "failureRate", "activeCount".
  /// Disambiguates rows within the same family if we add variants later.
  metricKey       String
  metricValue     Float
  sampleSize      Int
  monthYear       String

  /// Wave 6a (Phase 1) — usage class derived DETERMINISTICALLY from the in-code
  /// per-family sample floors (SAMPLE_THRESHOLDS in aggregated-metrics.ts), NOT
  /// from the LLM. `headline_safe` when the row's sample meets its family floor;
  /// `supporting_texture_only` for below-floor price-tier subgroups that are
  /// available as low-confidence colour. (`rejected` is unused on this model.)
  /// Overall (priceTier=null) rollups are always headline_safe — below-floor
  /// overalls are not persisted, preserving byte-identical parity with Wave 1.
  usageClass           FactUsageClass @default(headline_safe)

  yoyDelta             Float?
  rolling90dValue      Float?
  compositionShiftFlag Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([userId, uploadId, neighbourhood, propertyType, priceTier, metricFamily, metricKey])
  @@index([userId, neighbourhood, propertyType])
  @@index([userId, canonicalAreaId])
  @@index([uploadId])
  @@map("aggregated_metrics")
}

model MarketFact {
  id       String           @id @default(cuid())
  userId   String
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadId String
  upload   MarketDataUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  neighbourhood   String
  /// KB Merge & Clean — durable link to the canonical area (see AggregatedMetric).
  canonicalAreaId String?
  propertyType    String?
  priceTier       String?

  metricName        String
  metricFamily      MetricFamily
  metricValue       Float?
  metricValueString String?

  sampleSize  Int?
  timeWindow  String?
  dateContext DateTime?

  sourceUrl   String?
  sourceTitle String?
  notes       String? @db.Text

  marketType MarketType?
  trajectory Trajectory?
  usageClass FactUsageClass

  compositionShiftFlag Boolean  @default(false)
  triangulationStatus  String?
  yoyValue             Float?
  rolling90dValue      Float?
  crebAligned          Boolean?
  viewerCaveat         String?  @db.Text

  // Wave 1 Phase 2A — CREB-alignment + usage notes (all nullable, additive only)
  moiStrict            Float?
  moiInclusive         Float?
  domMedian            Float?
  domAverage           Float?
  crebDeltaEstimate    String? @db.Text
  inventoryGapWithCreb Float?
  failureRateFormula   String? @db.Text
  usageNotes           String? @db.Text

  // Three-layer data fallback — provenance of the fact row.
  //   "validator"            — produced by the market-data validator (default for all pre-existing rows)
  //   "on_demand_extraction" — Layer 2 paid CSV→Claude extraction (carries extractedAtCost)
  //   "member_provided"      — manually entered by the member via "Tell me what's missing" (texture-only, NOT validator-verified)
  sourceType         String?  @default("validator")
  extractedAtCost    Decimal? @db.Decimal(10, 4)
  extractedAtRequest String?

  // Methodology version for derived-metric facts (primarily FAILURE_RATE).
  //   "legacy_v1" — failure_rate computed as offMarket/(sold+offMarket) (WRONG denominator).
  //   "v2"        — failure_rate computed as offMarket/sold (broker-honest ratio, can exceed 1).
  // Card/script citation queries filter out legacy_v1 failure_rate rows so the
  // wrong methodology can't be surfaced until the upload is re-validated.
  methodologyVersion String? @default("v2")

  // Snapshot of the member's chosen metric methodology variants active at the
  // moment this prose fact was validated. Lets the re-validate endpoint detect
  // rows that are stale under updated settings, and gives admin tooling an audit
  // trail. Shape mirrors MemberMetricSettings:
  //   { moi, dom, failureRate, salePrice, sampleSize }
  // Null on rows written before this shipped (treat as the Default preset).
  methodologyVariant Json?

  createdAt DateTime @default(now())

  @@index([userId, neighbourhood])
  @@index([userId, canonicalAreaId])
  @@index([uploadId])
  @@index([metricFamily, usageClass])
  @@index([userId, sourceType])
  @@map("market_facts")
}

// ── Knowledge-Base Merge & Clean ─────────────────────────────────────────────
// Neighbourhood subdivision names fragment badly in raw MLS exports (e.g. 40
// "Woodbridge Ph 5B" / "Woodbridge 1" variants for one real place), which
// shatters per-area samples below the statistical floor. These three models are
// the ONLY mutation path for the per-member neighbourhood Knowledge Base —
// members never hand-edit it. A merge run normalizes raw names to a small set of
// CanonicalAreas (deterministic regex + a conservative fuzzy pass), records the
// raw→canonical mapping as AreaAliases, and re-aggregates facts on the canonical
// key so merged samples count together. See src/lib/kb-merge/.

enum MergeRunStatus {
  DRY_RUN // computed but not applied — the report the member reviews
  APPLYING // claimed by an in-progress apply; not yet fully re-aggregated
  APPLIED // confirmed and re-aggregated onto canonical areas
  DISCARDED // member rejected the proposed merges
}

// One real neighbourhood, after de-fragmentation. `name` is the canonical
// display form surfaced to the member and written into MarketFact.neighbourhood
// / AggregatedMetric.neighbourhood on re-aggregation.
model CanonicalArea {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  // Deterministic normalization key (see normalizeAreaName). Lets a new upload's
  // raw subdivision resolve to an existing canonical area without a fuzzy call.
  normKey   String
  aliases   AreaAlias[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([userId, name])
  @@index([userId, normKey])
  @@map("canonical_areas")
}

// A raw subdivision string seen in a member's MLS data and the canonical area it
// folds into. The permanent, non-destructive record of every merge decision —
// nothing is lost even though facts are re-aggregated.
model AreaAlias {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawName         String
  normKey         String
  canonicalAreaId String
  canonicalArea   CanonicalArea @relation(fields: [canonicalAreaId], references: [id], onDelete: Cascade)
  // How this alias was decided: "deterministic" (regex), "fuzzy" (Haiku >=0.9),
  // or "manual". Fuzzy aliases carry the model's confidence.
  source          String        @default("deterministic")
  confidence      Float?
  createdAt       DateTime      @default(now())

  @@unique([userId, rawName])
  @@index([userId, normKey])
  @@index([canonicalAreaId])
  @@map("area_aliases")
}

// An audit record + reviewable report for one merge/clean pass. Created as
// DRY_RUN (the "7,000 → ~400" summary the member confirms), flipped to APPLIED
// once re-aggregation runs, or DISCARDED if rejected. `report` holds the full
// before/after breakdown, proposed fuzzy merges, and the review queue.
model MergeRun {
  id                 String         @id @default(cuid())
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  status             MergeRunStatus @default(DRY_RUN)
  // "upload" | "manual" | "jarvis" — what triggered this run.
  source             String         @default("manual")
  uploadId           String?
  rawCount           Int            @default(0)
  canonicalCount     Int            @default(0)
  fuzzyProposedCount Int            @default(0)
  reviewQueueCount   Int            @default(0)
  report             Json
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  appliedAt          DateTime?

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("merge_runs")
}

// Member-facing neighbourhood hygiene — names the member explicitly removed
// from their Knowledge Base / market data (e.g. junk MLS area codes, "Unknown",
// misspellings). This is the persistent exclusion list: once a name is here it
// stays filtered out of cuts, the availability signal, and the vocab even after
// a FRESH CSV upload that still contains it — so re-uploading a messy export
// never resurrects the junk. `normName` is the case/space-insensitive match key
// (trim + lowercase). Removing a row (un-exclude) lets future uploads include
// the name again. Member-scoped; never touches another member's data.
model ExcludedNeighbourhood {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Display form as it appeared when excluded (for the "excluded" UI list).
  name      String
  // Normalized match key — trim + toLowerCase. All ingest/read filters compare
  // on this so casing/whitespace variants of the same junk name stay excluded.
  normName  String
  createdAt DateTime @default(now())

  @@unique([userId, normName])
  @@index([userId])
  @@map("excluded_neighbourhoods")
}

// Per-member metric methodology settings — "How we calculate your stats".
// One row per member; absent row == the Default preset (see DEFAULT_METHODOLOGY
// in src/lib/member-metric-settings.ts). Deterministic metrics switch instantly
// on save (all variants are persisted per upload); prose facts only change on a
// new upload or an explicit re-validate.
model MemberMetricSettings {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moiVariant         String   @default("active_plus_pending_single")
  domVariant         String   @default("average")
  failureRateVariant String   @default("all_off_market")
  salePriceVariant   String   @default("median")
  sampleSizeVariant  String   @default("conservative")
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  @@map("member_metric_settings")
}

model MarketStoryLead {
  id       String           @id @default(cuid())
  userId   String
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
