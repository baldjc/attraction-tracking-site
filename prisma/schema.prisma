generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  editor
  foundations_member
}

enum ServiceTier {
  foundations
  editing_2
  editing_4
  mastery_2
  mastery_4
}

enum AuditType {
  lead
  baseline
  monthly
  single_video
}

enum AIToolType {
  avatar_architect
  content_engine
  title_thumbnail_analyzer
  arc_script_builder
  script_review
}

enum JobStatus {
  queued
  downloading
  analysing
  generating
  complete
  failed
}

enum SourceType {
  YOUTUBE
  GOOGLE_ADS
  EMAIL
  OTHER
}

model User {
  id                String      @id @default(uuid())
  email             String      @unique
  fullName          String?
  passwordHash      String?
  magicLinkEnabled  Boolean     @default(false)
  emailVerified     Boolean     @default(false)
  role              UserRole    @default(foundations_member)
  ghlContactId        String?
  phone               String?
  youtubeChannelUrl   String?
  youtubeHandle       String?
  youtubeChannelName  String?
  serviceTier         ServiceTier @default(foundations)
  slackUserId       String?
  skoolProfile      String?
  coachingNotes          String?
  coachingNotesUpdatedAt DateTime?
  invitedAt              DateTime?
  lastLoginAt            DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  avatarProfile   Json?
  avatarName      String?
  avatarSummary   String?
  contentThemes   Json?
  niche           String?
  city            String?
  thankYouPageUrl     String?
  creatorCredentials  String?

  aiToolsMonthlyCapOverride  Decimal? @db.Decimal(10, 2)

  repurposeName     String?
  repurposeBusiness String?
  repurposeListSize String?
  repurposeVoice    String?
  savedLinks        Json?

  audits               Audit[]
  auditJobs            AuditJob[]
  campaigns            Campaign[]
  scriptReviews        ScriptReview[]
  savedScripts         SavedScript[]
  savedTitles          SavedTitle[]
  savedIdeas           SavedIdea[]
  titleAnalyses        TitleAnalysis[]
  aiToolConversations  AIToolConversation[]
  aiToolUsage          AIToolUsage[]
  repurposedContent    RepurposedContent[]

  @@map("users")
}

model ScriptReview {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle    String
  scriptText    String
  scores        Json
  overallScore  Float
  reportContent Json
  createdAt     DateTime @default(now())

  @@map("script_reviews")
}

model Audit {
  id             String    @id @default(uuid())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditType      AuditType
  overallScore   Float?
  scores         Json
  reportContent  Json
  videosAnalysed Json?
  notionPageId   String?
  notionPageUrl  String?
  reportMonth    String?
  createdAt      DateTime  @default(now())

  auditJob AuditJob?

  @@index([userId])
  @@index([auditType])
  @@map("audits")
}

model AuditJob {
  id           String    @id @default(uuid())
  auditType    AuditType
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       JobStatus @default(queued)
  errorMessage String?
  auditId      String?   @unique
  audit        Audit?    @relation(fields: [auditId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("audit_jobs")
}

model Campaign {
  id             String     @id @default(uuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  destinationUrl String
  sourceType     SourceType @default(YOUTUBE)
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  links TrackingLink[]

  @@index([userId])
  @@map("campaigns")
}

model TrackingLink {
  id                    String    @id @default(uuid())
  campaignId            String
  campaign              Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name                  String
  refCode               String    @unique
  youtubeVideoUrl       String?
  youtubeVideoId        String?
  youtubeThumbnailUrl   String?
  youtubeViewCount      Int       @default(0)
  youtubeViewsUpdatedAt DateTime?
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())

  clicks Click[]

  @@index([refCode])
  @@index([campaignId])
  @@map("tracking_links")
}

model Click {
  id             String       @id @default(uuid())
  trackingLinkId String
  link           TrackingLink @relation(fields: [trackingLinkId], references: [id], onDelete: Cascade)
  refCode        String
  sessionId      String
  ipAddress      String?
  city           String?
  province       String?
  country        String?
  userAgent      String?
  referrer       String?
  timestamp      DateTime     @default(now())

  pageViews PageView[]
  lead      Lead?

  @@index([trackingLinkId])
  @@index([refCode])
  @@index([sessionId])
  @@index([timestamp])
  @@map("clicks")
}

model PageView {
  id        String   @id @default(uuid())
  clickId   String
  click     Click    @relation(fields: [clickId], references: [id], onDelete: Cascade)
  pageUrl   String
  timestamp DateTime @default(now())

  @@index([clickId])
  @@map("page_views")
}

model Lead {
  id        String   @id @default(uuid())
  clickId   String   @unique
  click     Click    @relation(fields: [clickId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())

  @@index([clickId])
  @@map("leads")
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model SavedScript {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle    String
  scriptOutline Json
  arcScores     Json?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@map("saved_scripts")
}

model SavedTitle {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  framework String?
  topic     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("saved_titles")
}

model SavedIdea {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme         String
  title         String
  talkingPoints Json
  framework     String?
  whyItWorks    String?
  source        String   @default("batch")
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([userId, theme])
  @@map("saved_ideas")
}

model TitleAnalysis {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle String
  scores     Json
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("title_analyses")
}

model LoginOtp {
  id        String    @id @default(uuid())
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@map("login_otps")
}

model AIToolUsage {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolType       String
  inputTokens    Int
  outputTokens   Int
  costUsd        Decimal  @db.Decimal(10, 6)
  conversationId String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("ai_tool_usage")
}

model AIToolConversation {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolType      AIToolType
  title         String
  messages      Json
  metadata      Json?
  downloadCount Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([toolType])
  @@index([createdAt])
  @@map("ai_tool_conversations")
}

model RepurposedContent {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle   String
  toolType     String
  output       Json
  editedOutput String?
  createdAt    DateTime @default(now())

  @@index([userId, toolType, createdAt])
  @@map("repurposed_content")
}
