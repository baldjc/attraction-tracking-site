  status        TeamMemberStatus @default(active)
  acceptedAt    DateTime         @default(now())
  revokedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  primaryUser User @relation("TeamMemberPrimary", fields: [primaryUserId], references: [id], onDelete: Cascade)
  teamUser    User @relation("TeamMemberTeamUser", fields: [teamUserId], references: [id], onDelete: Cascade)

  @@unique([primaryUserId, teamUserId])
  @@index([primaryUserId])
  @@index([teamUserId])
  @@map("team_members")
}

// A pending invitation for an email address to gain team access to a primary's
// account. The raw token is emailed; only its hash is stored.
model TeamInvite {
  id            String           @id @default(uuid())
  primaryUserId String
  email         String
  tokenHash     String           @unique
  status        TeamInviteStatus @default(pending)
  sentAt        DateTime         @default(now())
  expiresAt     DateTime
  acceptedAt    DateTime?
  revokedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  primaryUser User @relation("TeamInvitePrimary", fields: [primaryUserId], references: [id], onDelete: Cascade)

  @@index([primaryUserId])
  @@index([email])
  @@map("team_invites")
}

// Append-only audit trail of every team-access state change, scoped to the
// primary account it concerns.
model TeamActivityLog {
  id            String        @id @default(uuid())
  primaryUserId String
  actorType     TeamActorType
  actorUserId   String?
  actorName     String?
  action        String
  metadata      Json?
  createdAt     DateTime      @default(now())

  primaryUser User @relation("TeamActivityLogPrimary", fields: [primaryUserId], references: [id], onDelete: Cascade)

  @@index([primaryUserId, createdAt])
  @@map("team_activity_logs")
}
