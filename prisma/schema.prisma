generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  editor
  foundations_member
  audit_lead
}

enum AuditRequestStatus {
  pending
  audited
}

enum ServiceTier {
  foundations
  editing_2
  editing_4
  mastery_2
  mastery_4
  done_with_you
}

enum AuditType {
  lead
  baseline
  monthly
  single_video
}

enum AIToolType {
  avatar_architect
  content_engine
  title_thumbnail_analyzer
  arc_script_builder
  script_review
  description_generator
  // Wave 0+ (data-first rebuild) — appended only, do not reorder
  fact_validator
  content_engine_v2
  script_builder_v2
  idea_validation
  knowledge_base_parse
}

enum JobStatus {
  queued
  downloading
  analysing
  generating
  complete
  failed
  cancelled
}

enum SourceType {
  YOUTUBE
  GOOGLE_ADS
  EMAIL
  EMAIL_NEWSLETTER
  META_ADS
  DIRECT_MAIL
  BLOG_POSTS
  OTHER
}

enum LeadStatus {
  New
  Audited
  Pitched
  Converted
  Lost
}

model User {
  id                String      @id @default(uuid())
  email             String      @unique
  fullName          String?
  passwordHash      String?
  magicLinkEnabled  Boolean     @default(false)
  emailVerified     Boolean     @default(false)
  role              UserRole    @default(foundations_member)
  ghlContactId        String?
  phone               String?
  youtubeChannelUrl   String?
  youtubeHandle       String?
  youtubeChannelName      String?
  youtubeChannelThumbnail String?
  serviceTier         ServiceTier @default(foundations)
  stripeCustomerId        String?   @unique
  stripeSubscriptionId    String?
  subscriptionStatus      String?
  stripePlanName          String?
  stripeCurrentPeriodEnd  DateTime?
  stripePriceAmount       Int?
  stripeCurrency          String?
  stripeLineItems         Json?
  lastPaymentReminderSentAt DateTime?
  slackUserId       String?
  skoolProfile      String?
  coachingNotes          String?
  coachingNotesUpdatedAt DateTime?
  invitedAt              DateTime?
  lastLoginAt            DateTime?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  allowedMemberIds  Json?

  avatarProfile   Json?
  videoThemes     String?
  avatarName      String?
  avatarSummary   String?
  contentThemes   Json?
  niche           Json?
  city            String?
  thankYouPageUrl     String?
  creatorCredentials  String?

  aiToolsMonthlyCapOverride  Decimal? @db.Decimal(10, 2)

  repurposeName     String?
  repurposeBusiness String?
  repurposeListSize String?
  repurposeVoice    String?
  savedLinks        Json?
  descriptionBoilerplate String? @db.Text

  // Onboarding
  onboardingComplete     Boolean   @default(false)
  onboardingDismissedAt  DateTime?
  // Onboarding Wizard (member/onboarding) — tracks linear progress through the
  // tier-aware multi-step setup flow. `onboardingStep` is the last COMPLETED
  // step (0 = not started). `onboardingCompletedAt` set when the member
  // finishes Step 9. `onboardingSkippedAt` set when they hit "Save and finish
  // later" — drives the dashboard nudge banner.
  onboardingStep         Int       @default(0)
  onboardingCompletedAt  DateTime?
  onboardingSkippedAt    DateTime?
  incomeGoal             String?
  postingRhythm          Int?
  biggestChallenge       String?

  // Lead pipeline (only meaningful while role = audit_lead)
  leadStatus             LeadStatus @default(New)
  convertedFromLeadAt    DateTime?

  lastYoutubeSyncAt    DateTime? @map("last_youtube_sync_at")

  assetsDriveLink  String?
  clientHubEnabled Boolean  @default(true)
  calendarToken    String?  @unique

  // Admin test avatar state (mutually exclusive — only one set at a time)
  activeTestAvatarId    String?   // Points to an AdminTestAvatar.id (custom avatar mode)
  activeTestMemberId    String?   // Points to a User.id whose avatar to borrow (member avatar mode)

  adminTestAvatars      AdminTestAvatar[] @relation("adminTestAvatars")

  audits               Audit[]
  auditJobs            AuditJob[]
  campaigns            Campaign[]
  scriptReviews        ScriptReview[]
  savedScripts         SavedScript[]
  savedTitles          SavedTitle[]
  savedIdeas           SavedIdea[]
  titleAnalyses        TitleAnalysis[]
  aiToolConversations  AIToolConversation[]
  aiToolUsage          AIToolUsage[]
  repurposedContent    RepurposedContent[]
  kbEntries            KnowledgeBaseEntry[]
  savedItems           SavedItem[]
  youtubeVideos        YouTubeVideo[]
  channelSnapshots     YouTubeChannelSnapshot[]
  workbookResponses    MemberWorkbookResponse[]
  lessonProgress       MemberLessonProgress[]
  homework             MemberHomework[]
  waitlistEntries      ServiceWaitlistEntry[]
  helpConversations    HelpConversation[]
  contentPlans         ContentPlan[]
  assignedPlans        ContentPlan[]    @relation("PlanAssignee")
  clientCalls          ClientCall[]     @relation("ClientCalls")
  createdCalls         ClientCall[]     @relation("CallCreator")
  quickLinks           ClientQuickLink[]
  scriptDrafts         ScriptDraft[]
  contentEngineDrafts  ContentEngineDraft[]
  contentEngineChatDrafts ContentEngineChatDraft[]
  changelogViews       ChangelogEntryView[]
  upgradeModalDismissals UpgradeModalDismissal[]
  planTeamNotes          PlanTeamNote[]      @relation("PlanTeamNoteAuthor")
  planAssignments        PlanAssignmentLog[] @relation("PlanAssignmentActor")

  reviewerTrackedChannels      ReviewerTrackedChannel[] @relation("ReviewerTrackedChannelMember")
  reviewerTrackedChannelsAdded ReviewerTrackedChannel[] @relation("ReviewerTrackedChannelAddedBy")

  // Wave 0 (data-first rebuild) — additive relations only
  marketConfig      MarketConfig?
  marketDataUploads MarketDataUpload[]
  marketFacts       MarketFact[]
  aggregatedMetrics AggregatedMetric[]
  marketStoryLeads  MarketStoryLead[]

  // Wave 1.5 (data-first rebuild) — additive relations only
  neighbourhoodProfiles        NeighbourhoodProfile[]
  neighbourhoodResearchUploads NeighbourhoodResearchUpload[]

  @@map("users")
}

model ReviewerTrackedChannel {
  id               String   @id @default(uuid())
  channelRef       String   @unique
  channelName      String
  channelHandle    String?
  channelThumbnail String?
  userId           String?
  user             User?    @relation("ReviewerTrackedChannelMember", fields: [userId], references: [id], onDelete: SetNull)
  addedById        String
  addedBy          User     @relation("ReviewerTrackedChannelAddedBy", fields: [addedById], references: [id])
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@map("reviewer_tracked_channels")
}

model ResourceLesson {
  id            String   @id @default(uuid())
  title         String
  lessonNumber  String
  sessionNumber Int
  skoolUrl      String   @default("")
  fullTranscript String  @db.Text
  principles    String[]
  createdAt     DateTime @default(now())

  @@map("course_lessons")
}

model QACall {
  id             String   @id @default(uuid())
  fathomId       String   @unique
  title          String
  callDate       DateTime
  fathomShareUrl String
  fullTranscript String   @db.Text
  duration       Int?
  status         String   @default("pending_review")
  errorMessage   String?
  createdAt      DateTime @default(now())

  @@map("qa_calls")
}

model KnowledgeBaseEntry {
  id                String   @id @default(uuid())
  sourceType        String
  sourceId          String
  principles        String[]
  subTopic          String   @default("")
  summary           String
  searchableText    String   @db.Text
  timestampStart    Int?
  timestampEnd      Int?
  memberId          String?
  member            User?    @relation(fields: [memberId], references: [id], onDelete: SetNull)
  isGeneralTeaching Boolean  @default(true)
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  savedItems SavedItem[]

  @@index([status])
  @@index([sourceType, sourceId])
  @@index([memberId])
  @@index([principles])
  @@map("knowledge_base_entries")
}

model SavedItem {
  id                   String             @id @default(uuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeBaseEntryId String
  knowledgeBaseEntry   KnowledgeBaseEntry @relation(fields: [knowledgeBaseEntryId], references: [id], onDelete: Cascade)
  savedAt              DateTime           @default(now())

  @@unique([userId, knowledgeBaseEntryId])
  @@map("saved_items")
}

model ScriptReview {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle    String
  scriptText    String
  scores        Json
  overallScore  Float
  reportContent Json
  createdAt     DateTime @default(now())

  @@map("script_reviews")
}

model Audit {
  id             String    @id @default(uuid())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditType      AuditType
  overallScore   Float?
  scores         Json
  reportContent  Json
  videosAnalysed Json?
  notionPageId   String?
  notionPageUrl  String?
  reportMonth    String?
  createdAt      DateTime  @default(now())

  youtubeVideoId String?       @map("youtube_video_id")
  youtubeVideo   YouTubeVideo? @relation(fields: [youtubeVideoId], references: [id])

  auditJob     AuditJob?
  auditRequest AuditRequest?

  @@index([userId])
  @@index([auditType])
  @@map("audits")
}

model AuditJob {
  id              String    @id @default(uuid())
  auditType       AuditType
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          JobStatus @default(queued)
  errorMessage    String?
  auditId         String?   @unique
  audit           Audit?    @relation(fields: [auditId], references: [id])
  auditRequestId  String?
  auditRequest    AuditRequest? @relation(fields: [auditRequestId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([auditRequestId])
  @@map("audit_jobs")
}

model Campaign {
  id             String     @id @default(uuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  destinationUrl String
  leadMagnetUrl  String?
  // Lead-magnet detail — feeds the script writer so it doesn't invent
  // generic pitches from the campaign name alone. See
  // src/app/api/ai-tools/script-builder-v2/route.ts ASSIGNED ASSETS block.
  description    String?
  pitchOneLiner  String?
  audience       String?
  sourceType     SourceType @default(YOUTUBE)
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  links        TrackingLink[]
  contentPlans ContentPlan[] @relation("PlanCampaign")

  @@index([userId])
  @@map("campaigns")
}

model TrackingLink {
  id                    String    @id @default(uuid())
  campaignId            String
  campaign              Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name                  String
  source                String    @default("youtube")
  destinationOverride   String    @default("landing_page")
  channel               String?
  refCode               String    @unique
  youtubeVideoUrl       String?
  youtubeVideoId        String?
  youtubeThumbnailUrl   String?
  youtubeViewCount      Int       @default(0)
  youtubeViewsUpdatedAt DateTime?
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())

  clicks Click[]

  @@index([refCode])
  @@index([campaignId])
  @@map("tracking_links")
}

model Click {
  id             String       @id @default(uuid())
  trackingLinkId String
  link           TrackingLink @relation(fields: [trackingLinkId], references: [id], onDelete: Cascade)
  refCode        String
  sessionId      String
  ipAddress      String?
  city           String?
  province       String?
  country        String?
  countryCode    String?
  userAgent      String?
  referrer       String?
  visitorType    String?      @map("visitor_type")
  timestamp      DateTime     @default(now())

  pageViews PageView[]
  lead      Lead?

  @@index([trackingLinkId])
  @@index([refCode])
  @@index([sessionId])
  @@index([timestamp])
  @@map("clicks")
}

model PageView {
  id        String   @id @default(uuid())
  clickId   String
  click     Click    @relation(fields: [clickId], references: [id], onDelete: Cascade)
  pageUrl   String
  timestamp DateTime @default(now())

  @@index([clickId])
  @@map("page_views")
}

model Lead {
  id        String   @id @default(uuid())
  clickId   String   @unique
  click     Click    @relation(fields: [clickId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())

  @@index([clickId])
  @@map("leads")
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model SavedScript {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle    String
  scriptOutline Json
  arcScores     Json?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@map("saved_scripts")
}

model SavedTitle {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  framework String?
  topic     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("saved_titles")
}

model SavedIdea {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme         String
  title         String
  talkingPoints Json
  dataToFind    String?
  framework     String?
  whyItWorks    String?
  source        String   @default("batch")
  createdAt     DateTime @default(now())

  // Wave 0 (data-first rebuild) — all nullable, backward compatible
  rotationSlot      RotationSlot?
  titlePromise      String?       @db.Text
  citedFactIds      Json?
  linkedStoryLeadId String?
  shootType         ShootType?
  tactileType       String?
  visualPeak        String?       @db.Text

  @@index([userId])
  @@index([userId, theme])
  @@map("saved_ideas")
}

model TitleAnalysis {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle String
  scores     Json
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("title_analyses")
}

model LoginOtp {
  id        String    @id @default(uuid())
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@map("login_otps")
}

model AIToolUsage {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolType       String
  inputTokens    Int
  outputTokens   Int
  costUsd        Decimal  @db.Decimal(10, 6)
  conversationId String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("ai_tool_usage")
}

model AIToolConversation {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolType      AIToolType
  title         String
  messages      Json
  metadata      Json?
  downloadCount Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([toolType])
  @@index([createdAt])
  @@map("ai_tool_conversations")
}

model RepurposedContent {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoTitle   String
  toolType     String
  output       Json
  editedOutput String?
  createdAt    DateTime @default(now())

  @@index([userId, toolType, createdAt])
  @@map("repurposed_content")
}

model YouTubeVideo {
  id           String   @id @default(uuid())
  userId       String
  videoId      String
  title        String
  publishedAt  DateTime
  thumbnailUrl String?
  viewCount    Int      @default(0)
  likeCount    Int      @default(0)
  commentCount Int      @default(0)
  duration     String?
  discoveredAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  audits Audit[]

  @@unique([userId, videoId])
  @@map("youtube_videos")
}

model YouTubeChannelSnapshot {
  id              String   @id @default(uuid())
  userId          String
  subscriberCount Int
  totalVideoCount Int
  totalViewCount  BigInt
  snapshotAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("youtube_channel_snapshots")
}

// ── Academy / Foundations Library ────────────────────────────────────────────

model CourseSection {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?  @db.Text
  sortOrder   Int
  published   Boolean  @default(true)
  moduleType  String   @default("foundations")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons CourseLesson[]

  @@map("course_sections")
}

model CourseLesson {
  id            String   @id @default(uuid())
  sectionId     String
  title         String
  slug          String   @unique
  youtubeUrl    String?
  description   String?  @db.Text
  keyTakeaways  String?  @db.Text
  actionItems   String?  @db.Text
  sortOrder     Int
  published     Boolean  @default(true)
  principleTags Json     @default("[]")
  aiToolLink    String?
  aiToolLabel   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  section        CourseSection          @relation(fields: [sectionId], references: [id])
  workbookFields LessonWorkbookField[]
  progress       MemberLessonProgress[]
  homework       MemberHomework[]

  @@map("academy_lessons")
}

model LessonWorkbookField {
  id              String   @id @default(uuid())
  lessonId        String
  fieldType       String
  label           String
  placeholderText String?
  sortOrder       Int
  config          Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lesson    CourseLesson             @relation(fields: [lessonId], references: [id])
  responses MemberWorkbookResponse[]

  @@map("lesson_workbook_fields")
}

model MemberWorkbookResponse {
  id              String   @id @default(uuid())
  userId          String
  workbookFieldId String
  response        Json
  updatedAt       DateTime @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  workbookField LessonWorkbookField @relation(fields: [workbookFieldId], references: [id])

  @@unique([userId, workbookFieldId])
  @@map("member_workbook_responses")
}

model MemberLessonProgress {
  id          String    @id @default(uuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson CourseLesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@map("member_lesson_progress")
}

model MemberHomework {
  id            String   @id @default(uuid())
  userId        String
  lessonId      String
  homeworkItems Json
  updatedAt     DateTime @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson CourseLesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@map("member_homework")
}

model ServiceCategory {
  id                String   @id @default(uuid())
  name              String
  slug              String   @unique
  description       String?
  icon              String   @default("PuzzlePieceIcon")
  accentColour      String   @default("blue")
  sortOrder         Int      @default(0)
  published         Boolean  @default(true)
  emoji             String?
  tagline           String?
  highlighted       Boolean  @default(false)
  includesRef       String?
  cardExtras        Json?
  addonLabel        String?
  addonPriceNote    String?
  footerNote        String?
  jaredIncludedNote String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  packages          ServicePackage[]

  @@map("service_categories")
}

model ServicePackage {
  id                String   @id @default(uuid())
  categoryId        String
  name              String
  price             String
  priceNote         String?
  badge             String?
  subtitle          String?
  features          Json     @default("[]")
  highlightFeatures Json?
  stripeUrl         String?
  waitlist          Boolean  @default(false)
  sortOrder         Int      @default(0)
  published         Boolean  @default(true)
  videoCount        Int?
  isAddonVariant    Boolean  @default(false)
  priceAmount       Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  category          ServiceCategory @relation(fields: [categoryId], references: [id])
  waitlistEntries   ServiceWaitlistEntry[]

  @@map("service_packages")
}

model ServiceWaitlistEntry {
  id        String   @id @default(uuid())
  packageId String
  userId    String
  message   String?
  createdAt DateTime @default(now())
  package   ServicePackage @relation(fields: [packageId], references: [id])
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([packageId, userId])
  @@map("service_waitlist_entries")
}

model HelpConversation {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  HelpMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
  @@map("help_conversations")
}

model HelpMessage {
  id             String           @id @default(uuid())
  conversationId String
  conversation   HelpConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String           @db.Text
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@map("help_messages")
}

model SiteConfig {
  id                Int      @id @default(autoincrement())
  key               String   @unique
  value             String
  label             String?
  fieldType         String   @default("text") @map("field_type")
  category          String   @default("webinar")
  ghlCustomValueKey String?  @map("ghl_custom_value_key")
  sortOrder         Int      @default(0) @map("sort_order")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy         String?  @map("updated_by")

  @@map("site_config")
}

model AuditRequest {
  id                   String             @id @default(uuid())
  fullName             String
  email                String
  phone                String?
  youtubeChannelUrl    String
  currentYoutubeIncome String?
  desiredYoutubeIncome String?
  status               AuditRequestStatus @default(pending)
  userId               String?
  auditId              String?            @unique
  audit                Audit?             @relation(fields: [auditId], references: [id], onDelete: SetNull)
  auditJobs            AuditJob[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([email])
  @@index([status])
  @@map("audit_requests")
}

enum WebhookLogStatus {
  success
  deduplicated
  rejected_bad_token
  rejected_missing_fields
  error
}

enum WebhookSource {
  ghl_audit_request
}

model WebhookLog {
  id        String           @id @default(uuid())
  source    WebhookSource
  status    WebhookLogStatus
  email     String?
  message   String?
  payload   Json
  createdAt DateTime         @default(now())

  @@index([source, createdAt])
  @@index([status])
  @@map("webhook_logs")
}

model ContentPlan {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  status          String    @default("Idea")
  theme           String?
  shootDate       DateTime?
  shootLocation   String?
  publishDate     DateTime?
  editDueDate     DateTime?
  priority        String?
  notes           String?   @db.Text
  script          String?   @db.Text
  youtubeDescription String? @db.Text
  researchNotes   String?   @db.Text
  // Free-form scratchpad for the member's own notes & thoughts about this
  // video — separate from `notes` (talking points / outline) and
  // `researchNotes` (sourced facts) so the structured fields stay clean.
  thoughts        String?   @db.Text
  // Manual progress-track overrides — array of step keys ("idea","script",
  // "review","title","description","repurpose","ready") the user has ticked
  // by hand. Combined with auto-detection (OR) when rendering ProgressTrack.
  manualSteps     Json?
  thumbnailWords  String?
